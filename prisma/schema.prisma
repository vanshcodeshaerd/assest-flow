generator client {
  provider   = "prisma-client-js"
  engineType = "binary"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id              String       @id @default(uuid())
  name            String?
  firstName       String?
  lastName        String?
  employeeId      String?      @unique
  email           String       @unique
  passwordHash    String
  department      String?
  phone           String?
  departmentId    String?
  role            String       @default("EMPLOYEE")
  status          String       @default("ACTIVE")
  isActive        Boolean      @default(true)
  approvedBy      String?
  approvedAt      DateTime?
  joinedAt        DateTime?
  deletedAt       DateTime?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  departmentRef   Department?  @relation(fields: [departmentId], references: [id])
  headOf          Department[] @relation("DepartmentHead")

  loginHistory    LoginHistory[]
  refreshTokens   RefreshToken[]
  passwordResets  PasswordReset[]
  bookings        Booking[]
  allocations     Allocation[]
  maintenanceReqs MaintenanceRequest[]
  activityLogs    ActivityLog[]
  notifications   Notification[]
  roleHistory     RoleHistory[]
}

model RoleHistory {
  id          String   @id @default(uuid())
  employeeId  String
  oldRole     String
  newRole     String
  changedBy   String
  changedAt   DateTime @default(now())

  employee    User     @relation(fields: [employeeId], references: [id])
}

model AuditLog {
  id          String   @id @default(uuid())
  action      String
  performedBy String
  targetId    String?
  entity      String
  metadata    String?
  createdAt   DateTime @default(now())
}

model Department {
  id              String       @id @default(uuid())
  name            String       @unique
  code            String       @unique
  description     String?
  parentDeptId    String?
  headId          String?
  status          String       @default("ACTIVE")
  createdBy       String?
  deletedAt       DateTime?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  parentDepartment Department?  @relation("DepartmentHierarchy", fields: [parentDeptId], references: [id])
  subDepartments   Department[] @relation("DepartmentHierarchy")

  departmentHead  User?        @relation("DepartmentHead", fields: [headId], references: [id])
  users           User[]
  assets          Asset[]
}

model AssetCategory {
  id              String       @id @default(uuid())
  name            String       @unique
  code            String       @unique
  description     String?
  status          String       @default("ACTIVE")
  deletedAt       DateTime?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  customFields    String?
  assets          Asset[]
}

model Asset {
  id              String       @id @default(uuid())
  assetId         String       @unique
  assetTag        String       @unique
  name            String
  serialNumber    String?      @unique
  categoryId      String
  departmentId    String?
  brand           String?
  model           String?
  manufacturer    String?
  vendor          String?
  description     String?
  notes           String?
  condition       String       @default("GOOD")
  location        String?
  storageRoom     String?
  purchaseDate    DateTime?
  purchaseCost    Float?
  warrantyExpiry  DateTime?
  status          String       @default("AVAILABLE")
  healthScore     Int?         @default(100)
  usageScore      String?      @default("LOW")
  riskScore       String?      @default("LOW")
  isShared        Boolean      @default(false)
  qrCode          String?
  photo           String?
  assignedTo      String?
  assignedManager String?
  deletedAt       DateTime?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  category        AssetCategory @relation(fields: [categoryId], references: [id])
  department      Department?   @relation(fields: [departmentId], references: [id])

  allocations     Allocation[]
  bookings        Booking[]
  maintenance     MaintenanceRequest[]
  auditRecords    AuditRecord[]
  transfers       AssetTransfer[]
  timeline        AssetTimeline[]
  documents       AssetDocument[]
}

model AssetDocument {
  id          String   @id @default(uuid())
  assetId     String
  fileName    String
  fileType    String
  fileSize    Int?
  url         String
  docType     String   @default("OTHER")
  uploadedAt  DateTime @default(now())

  asset       Asset    @relation(fields: [assetId], references: [id])
}

model AssetTransfer {
  id              String   @id @default(uuid())
  assetId         String
  fromEmployeeId  String?
  toEmployeeId    String?
  fromDepartmentId String?
  toDepartmentId  String?
  fromLocation    String?
  toLocation      String?
  reason          String?
  approvedBy      String?
  createdAt       DateTime @default(now())

  asset           Asset    @relation(fields: [assetId], references: [id])
}

model AssetTimeline {
  id          String   @id @default(uuid())
  assetId     String
  event       String
  performedBy String?
  metadata    String?
  createdAt   DateTime @default(now())

  asset       Asset    @relation(fields: [assetId], references: [id])
}

model Booking {
  id              String       @id @default(uuid())
  assetId         String
  employeeId      String
  startTime       DateTime
  endTime         DateTime
  status          String       @default("UPCOMING")

  asset           Asset        @relation(fields: [assetId], references: [id])
  employee        User         @relation(fields: [employeeId], references: [id])
}

model Allocation {
  id              String       @id @default(uuid())
  assetId         String
  holderId        String
  allocatedBy     String?
  allocatedDate   DateTime     @default(now())
  expectedReturn  DateTime?
  returnDate      DateTime?
  returnedAt      DateTime?
  approvedBy      String?
  notes           String?
  status          String       @default("ACTIVE")

  asset           Asset        @relation(fields: [assetId], references: [id])
  holder          User         @relation(fields: [holderId], references: [id])
}

model MaintenanceRequest {
  id              String       @id @default(uuid())
  assetId         String
  raisedById      String
  type            String       @default("CORRECTIVE")
  priority        String       @default("MEDIUM")
  description     String
  vendor          String?
  engineer        String?
  cost            Float?
  beforeCondition String?
  afterCondition  String?
  scheduledDate   DateTime?
  completedDate   DateTime?
  status          String       @default("SCHEDULED")
  technicianId    String?
  attachments     String?

  asset           Asset        @relation(fields: [assetId], references: [id])
  raisedBy        User         @relation(fields: [raisedById], references: [id])

  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
}

model AuditCycle {
  id              String       @id @default(uuid())
  name            String
  startDate       DateTime     @default(now())
  endDate         DateTime?
  status          String       @default("OPEN")

  records         AuditRecord[]
}

model AuditRecord {
  id              String       @id @default(uuid())
  cycleId         String
  auditorId       String
  assetId         String
  status          String
  remarks         String?

  cycle           AuditCycle   @relation(fields: [cycleId], references: [id])
  asset           Asset        @relation(fields: [assetId], references: [id])
}

model Notification {
  id              String       @id @default(uuid())
  userId          String
  title           String
  description     String
  isRead          Boolean      @default(false)
  createdAt       DateTime     @default(now())

  user            User         @relation(fields: [userId], references: [id])
}

model ActivityLog {
  id              String       @id @default(uuid())
  userId          String
  action          String
  entity          String
  entityId        String?
  ip              String?
  timestamp       DateTime     @default(now())

  user            User         @relation(fields: [userId], references: [id])
}

model LoginHistory {
  id        String   @id @default(uuid())
  userId    String
  timestamp DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}

model RefreshToken {
  id        String   @id @default(uuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  revokedAt DateTime?
  replacedByTokenHash String?
  ipAddress String?
  device    String?
  browser   String?

  user      User     @relation(fields: [userId], references: [id])
}

model PasswordReset {
  id        String   @id @default(uuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id])
}
